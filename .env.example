# ── Database Configuration ──────────────────────────────────────────────────────
# SQLite (development – no installation needed)
DATABASE_URL=sqlite:///physics_sim.db

# PostgreSQL (production – uncomment and fill in credentials)
# DATABASE_URL=postgresql://user:password@localhost:5432/physics_db

# ── Flask Configuration ─────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true

# ── ETL Configuration ───────────────────────────────────────────────────────────
ETL_SCHEDULE_HOURS=24
DATA_RETENTION_DAYS=90

# ── Analytics ───────────────────────────────────────────────────────────────────
ANALYTICS_ENABLED=true
